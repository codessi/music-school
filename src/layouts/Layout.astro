---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#071F20" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Evergrow Music School — piano, guitar, ukulele, and music theory lessons in Los Angeles."
		/>
		<title>Evergrow Music School</title>
		<slot name="head" />
	</head>
	<body class="m-0 min-h-screen bg-slate-950 p-0 text-white antialiased">
		<slot />
	</body>
</html>
