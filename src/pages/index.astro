---
import Layout from "../layouts/Layout.astro";
import { fetchSanity, sanityConfigured } from "../lib/sanity";

interface HeroContent {
  badge: string;
  headline: string;
  description: string;
  youtubeVideoId: string;
  offerLabel: string;
  offerHeadline: string;
  offerDescription: string;
  featureChips: string[];
  socialProof: {
    students: string;
    instructors: string;
    locations: string;
  };
}

const defaultHero: HeroContent = {
  badge: "Angel Music Academy",
  headline: "Let's Play Music",
  description:
    "Build confidence, technique, and creativity with one-on-one coaching from experienced instructors. Lessons are available for all ages and skill levels.",
  youtubeVideoId: "NxzJp2v1Mi4",
  offerLabel: "Limited Time Offer",
  offerHeadline: "Spring Into Music - 25% Off",
  offerDescription: "First lesson free when you book this week.",
  featureChips: ["Ages 5 to Adult", "Flexible Scheduling", "3 LA Locations"],
  socialProof: {
    students: "1,650+",
    instructors: "103",
    locations: "3",
  },
};

const heroQuery = `*[_type == "heroSection" && slug.current == "home"][0]{
  badge,
  headline,
  description,
  youtubeVideoId,
  offerLabel,
  offerHeadline,
  offerDescription,
  featureChips,
  socialProof
}`;

const sanityHero = await fetchSanity<Partial<HeroContent>>(heroQuery);
const pickText = (value: unknown, fallback: string): string =>
  typeof value === "string" && value.trim().length > 0 ? value : fallback;
const pickChips = (value: unknown, fallback: string[]): string[] =>
  Array.isArray(value) &&
  value.some((item) => typeof item === "string" && item.trim().length > 0)
    ? value.filter(
        (item): item is string =>
          typeof item === "string" && item.trim().length > 0,
      )
    : fallback;

const hero: HeroContent = {
  badge: pickText(sanityHero?.badge, defaultHero.badge),
  headline: pickText(sanityHero?.headline, defaultHero.headline),
  description: pickText(sanityHero?.description, defaultHero.description),
  youtubeVideoId: pickText(
    sanityHero?.youtubeVideoId,
    defaultHero.youtubeVideoId,
  ),
  offerLabel: pickText(sanityHero?.offerLabel, defaultHero.offerLabel),
  offerHeadline: pickText(sanityHero?.offerHeadline, defaultHero.offerHeadline),
  offerDescription: pickText(
    sanityHero?.offerDescription,
    defaultHero.offerDescription,
  ),
  featureChips: pickChips(sanityHero?.featureChips, defaultHero.featureChips),
  socialProof: {
    students: pickText(
      sanityHero?.socialProof?.students,
      defaultHero.socialProof.students,
    ),
    instructors: pickText(
      sanityHero?.socialProof?.instructors,
      defaultHero.socialProof.instructors,
    ),
    locations: pickText(
      sanityHero?.socialProof?.locations,
      defaultHero.socialProof.locations,
    ),
  },
};
---

<Layout>
  <main class="relative min-h-screen overflow-hidden bg-slate-950">
    <iframe
      class="absolute inset-0 z-0 h-full w-full scale-125 object-cover"
      src={`https://www.youtube.com/embed/${hero.youtubeVideoId}?autoplay=1&mute=1&loop=1&playlist=${hero.youtubeVideoId}&controls=0&modestbranding=1&playsinline=1&rel=0`}
      title="Hero background video"
      allow="autoplay; encrypted-media; picture-in-picture"
      referrerpolicy="strict-origin-when-cross-origin"></iframe>
    <div
      class="pointer-events-none absolute inset-0 z-10 bg-[linear-gradient(110deg,rgba(2,6,23,0.66)_18%,rgba(2,6,23,0.42)_58%,rgba(2,6,23,0.62)_100%)]"
    >
    </div>

    <div class="relative z-20 flex min-h-screen flex-col">
      <header>
        <nav
          class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-6 md:px-10"
        >
          <a href="#" class="text-xl font-bold tracking-wide text-white"
            >Angeles</a
          >
          <div class="hidden items-center gap-8 text-sm text-slate-100 md:flex">
            <a href="#" class="transition hover:text-white">Home</a>
            <a href="#" class="transition hover:text-white">About</a>
            <a href="#" class="transition hover:text-white">Instruments</a>
            <a href="#" class="transition hover:text-white">Locations</a>
            <a href="#" class="transition hover:text-white">Contact</a>
          </div>
          <a
            href="#lead-form"
            class="rounded-full bg-rose-500 px-5 py-2 text-xs font-semibold uppercase tracking-wider text-white shadow-lg shadow-rose-600/35 transition hover:bg-rose-400"
          >
            Student Login
          </a>
        </nav>
      </header>
      <!-- hero section -->
      <section
        class=" mx-auto flex flex-1 w-full max-w-7xl items-end px-6 pb-16 md:px-10 md:pt-10"
      >
        <div class="flex justify-between w-full">
          <div class=" flex justify-end flex-col">
            <p
              class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-emerald-300"
            >
              {hero.badge}
            </p>
            <h1 class="max-w-lg text-8xl  font-bold leading-tight ">
              {hero.headline}
            </h1>
            <p
              class="mt-6 max-w-xl text-xl leading-relaxed text-slate-200 md:text-4xl"
            >
              {hero.description}
            </p>
            <div class="mt-8 flex flex-wrap gap-3 text-sm text-slate-200">
              {
                hero.featureChips.map((chip) => (
                  <span class="rounded-full border border-white/30 bg-white/10 px-4 py-2">
                    {chip}
                  </span>
                ))
              }
            </div>
          </div>
          <!-- lead form -->
          <div
            class="rounded-3xl border max-w-[400px] border-slate-200/10 bg-white p-8 text-slate-900 shadow-2xl shadow-black/40 -mb-10 md:p-10"
          >
            <div id="lead-form"></div>
            <p
              class="text-center text-sm font-semibold uppercase tracking-[0.15em] text-rose-500"
            >
              {hero.offerLabel}
            </p>
            <h2 class="mt-2 text-center text-3xl font-bold leading-tight">
              {hero.offerHeadline}
            </h2>
            <p class="mt-2 text-center text-sm text-slate-500">
              {hero.offerDescription}
            </p>

					<div class="mt-8 rounded-xl border border-slate-200 bg-slate-50/70 p-3">
						<script
							src="https://app.mymusicstaff.com/Widget/v4/Widget.ashx?settings=eyJTY2hvb2xJRCI6InNjaF9yVjFKQyIsIldlYnNpdGVJRCI6Indic19kMW5KViIsIldlYnNpdGVCbG9ja0lEIjoid2JiX3pGUjVwSlEifQ=="
						></script>
					</div>
          </div>
        </div>
      </section>
    </div>
    <!-- soci -->
    <div class="border-t border-white/15 bg-black/40 backdrop-blur-md">
      {
        !sanityConfigured() && (
          <p class="px-6 pt-4 text-center text-xs text-slate-300 md:px-10">
            Add `SANITY_PROJECT_ID` and `SANITY_DATASET` in `.env` to load CMS
            content.
          </p>
        )
      }
      <div
        class="mx-auto grid max-w-7xl gap-4 px-6 py-4 sm:grid-cols-3 md:px-10"
      >
        <div
          class="flex items-center justify-center gap-3 rounded-xl border border-white/15 bg-white/5 px-4 py-3"
        >
          <span class="text-2xl">🎓</span>
          <div>
            <p class="text-lg font-bold">{hero.socialProof.students}</p>
            <p class="text-xs uppercase tracking-wide text-slate-300">
              Students
            </p>
          </div>
        </div>
        <div
          class="flex items-center justify-center gap-3 rounded-xl border border-white/15 bg-white/5 px-4 py-3"
        >
          <span class="text-2xl">👩‍🏫</span>
          <div>
            <p class="text-lg font-bold">{hero.socialProof.instructors}</p>
            <p class="text-xs uppercase tracking-wide text-slate-300">
              Instructors
            </p>
          </div>
        </div>
        <div
          class="flex items-center justify-center gap-3 rounded-xl border border-white/15 bg-white/5 px-4 py-3"
        >
          <span class="text-2xl">📍</span>
          <div>
            <p class="text-lg font-bold">{hero.socialProof.locations}</p>
            <p class="text-xs uppercase tracking-wide text-slate-300">
              Locations
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
