---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="relative min-h-screen overflow-hidden bg-slate-950">
		<iframe
			class="absolute inset-0 h-full w-full scale-125 object-cover"
			src="https://www.youtube.com/embed/NxzJp2v1Mi4?autoplay=1&mute=1&loop=1&playlist=NxzJp2v1Mi4&controls=0&modestbranding=1&playsinline=1&rel=0"
			title="Hero background video"
			allow="autoplay; encrypted-media; picture-in-picture"
			referrerpolicy="strict-origin-when-cross-origin"
		></iframe>
		<div class="absolute inset-0 bg-[linear-gradient(110deg,rgba(2,6,23,0.88)_18%,rgba(2,6,23,0.62)_58%,rgba(2,6,23,0.82)_100%)]"></div>

		<header class="absolute inset-x-0 top-0 z-30">
			<nav class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-6 md:px-10">
				<a href="#" class="text-xl font-bold tracking-wide text-white">Angeles</a>
				<div class="hidden items-center gap-8 text-sm text-slate-100 md:flex">
					<a href="#" class="transition hover:text-white">Home</a>
					<a href="#" class="transition hover:text-white">About</a>
					<a href="#" class="transition hover:text-white">Instruments</a>
					<a href="#" class="transition hover:text-white">Locations</a>
					<a href="#" class="transition hover:text-white">Contact</a>
				</div>
				<a
					href="#lead-form"
					class="rounded-full bg-rose-500 px-5 py-2 text-xs font-semibold uppercase tracking-wider text-white shadow-lg shadow-rose-600/35 transition hover:bg-rose-400"
				>
					Student Login
				</a>
			</nav>
		</header>
<!-- hero section -->
		<section class="relative z-20 mx-auto flex min-h-screen max-w-7xl items-center px-6 pb-28 pt-28 md:px-10 md:pt-36">
			<div class="grid w-full gap-8 lg:grid-cols-[1.1fr_0.9fr]">
				<div
					class=""
				>
					<p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-emerald-300">
						Los Angeles Music Academy
					</p>
					<h1 class="max-w-lg text-4xl font-bold leading-tight md:text-6xl">
						Private Music Lessons in Los Angeles
					</h1>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-200 md:text-lg">
						Build confidence, technique, and creativity with one-on-one coaching from experienced
						instructors. Lessons are available for all ages and skill levels.
					</p>
					<div class="mt-8 flex flex-wrap gap-3 text-sm text-slate-200">
						<span class="rounded-full border border-white/30 bg-white/10 px-4 py-2">Ages 5 to Adult</span>
						<span class="rounded-full border border-white/30 bg-white/10 px-4 py-2">Flexible Scheduling</span>
						<span class="rounded-full border border-white/30 bg-white/10 px-4 py-2">3 LA Locations</span>
					</div>
				</div>

				<div
					class="rounded-3xl border border-slate-200/10 bg-white p-8 text-slate-900 shadow-2xl shadow-black/40 md:p-10"
				>
					<div id="lead-form"></div>
					<p class="text-center text-sm font-semibold uppercase tracking-[0.15em] text-rose-500">
						Limited Time Offer
					</p>
					<h2 class="mt-2 text-center text-3xl font-bold leading-tight">
						Spring Into Music - 25% Off
					</h2>
					<p class="mt-2 text-center text-sm text-slate-500">
						First lesson free when you book this week.
					</p>

					<form class="mt-8 space-y-4">
						<div class="grid gap-4 md:grid-cols-2">
							<input
								type="text"
								name="name"
								placeholder="Name"
								class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-rose-500 focus:ring-2 focus:ring-rose-200"
								required
							/>
							<input
								type="email"
								name="email"
								placeholder="Email"
								class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-rose-500 focus:ring-2 focus:ring-rose-200"
								required
							/>
						</div>
						<div class="grid gap-4 md:grid-cols-2">
							<input
								type="tel"
								name="phone"
								placeholder="Phone"
								class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-rose-500 focus:ring-2 focus:ring-rose-200"
								required
							/>
							<select
								name="instrument"
								class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-rose-500 focus:ring-2 focus:ring-rose-200"
								required
							>
								<option value="" disabled selected>Select Instrument</option>
								<option value="Piano">Piano</option>
								<option value="Violin">Violin</option>
								<option value="Voice">Voice</option>
								<option value="Guitar">Guitar</option>
							</select>
						</div>
						<button
							type="submit"
							class="w-full rounded-xl bg-linear-to-r from-rose-500 to-red-500 px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white shadow-lg shadow-rose-500/35 transition hover:from-rose-400 hover:to-red-400"
						>
							Book My Free Trial
						</button>
					</form>
				</div>
			</div>
		</section>
<!-- soci -->
		<div class="absolute inset-x-0 bottom-0 z-20 border-t border-white/15 bg-black/40 backdrop-blur-md">
			<div class="mx-auto grid max-w-7xl gap-4 px-6 py-4 sm:grid-cols-3 md:px-10">
				<div class="flex items-center justify-center gap-3 rounded-xl border border-white/15 bg-white/5 px-4 py-3">
					<span class="text-2xl">🎓</span>
					<div>
						<p class="text-lg font-bold">1,650+</p>
						<p class="text-xs uppercase tracking-wide text-slate-300">Students</p>
					</div>
				</div>
				<div class="flex items-center justify-center gap-3 rounded-xl border border-white/15 bg-white/5 px-4 py-3">
					<span class="text-2xl">👩‍🏫</span>
					<div>
						<p class="text-lg font-bold">103</p>
						<p class="text-xs uppercase tracking-wide text-slate-300">Instructors</p>
					</div>
				</div>
				<div class="flex items-center justify-center gap-3 rounded-xl border border-white/15 bg-white/5 px-4 py-3">
					<span class="text-2xl">📍</span>
					<div>
						<p class="text-lg font-bold">3</p>
						<p class="text-xs uppercase tracking-wide text-slate-300">Locations</p>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>
