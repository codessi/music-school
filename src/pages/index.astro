---
import Layout from "../layouts/Layout.astro";
import { fetchSanity, sanityConfigured } from "../lib/sanity";

interface HeroContent {
  badge: string;
  headline: string;
  description: string;
  youtubeVideoId: string;
  offerLabel: string;
  offerHeadline: string;
  offerDescription: string;
  featureChips: string[];
  socialProof: {
    students: string;
    instructors: string;
    locations: string;
  };
}

const defaultHero: HeroContent = {
  badge: "evergrow music school",
  headline: "Music Lessons in Los Angeles",
  description: `Sharing music since 2014. Serving LA 90004 and the surrounding areas. Lessons are available at the student’s home, the teacher’s studio, or online.`,
  youtubeVideoId: "NxzJp2v1Mi4",
  offerLabel: "Limited Time Offer",
  offerHeadline: "Spring Into Music - 25% Off",
  offerDescription: "First lesson free when you book this week.",
  featureChips: ["Ages 5 to Adult", "Flexible Scheduling"],
  socialProof: {
    students: "1,650+",
    instructors: "103",
    locations: "3",
  },
};

const heroQuery = `*[_type == "heroSection" && slug.current == "home"][0]{
  badge,
  headline,
  description,
  youtubeVideoId,
  offerLabel,
  offerHeadline,
  offerDescription,
  featureChips,
  socialProof
}`;

const sanityHero = await fetchSanity<Partial<HeroContent>>(heroQuery);
const pickText = (value: unknown, fallback: string): string =>
  typeof value === "string" && value.trim().length > 0 ? value : fallback;
const pickChips = (value: unknown, fallback: string[]): string[] =>
  Array.isArray(value) &&
  value.some((item) => typeof item === "string" && item.trim().length > 0)
    ? value.filter(
        (item): item is string =>
          typeof item === "string" && item.trim().length > 0,
      )
    : fallback;

const hero: HeroContent = {
  badge: pickText(sanityHero?.badge, defaultHero.badge),
  headline: pickText(sanityHero?.headline, defaultHero.headline),
  description: pickText(sanityHero?.description, defaultHero.description),
  youtubeVideoId: pickText(
    sanityHero?.youtubeVideoId,
    defaultHero.youtubeVideoId,
  ),
  offerLabel: pickText(sanityHero?.offerLabel, defaultHero.offerLabel),
  offerHeadline: pickText(sanityHero?.offerHeadline, defaultHero.offerHeadline),
  offerDescription: pickText(
    sanityHero?.offerDescription,
    defaultHero.offerDescription,
  ),
  featureChips: pickChips(sanityHero?.featureChips, defaultHero.featureChips),
  socialProof: {
    students: pickText(
      sanityHero?.socialProof?.students,
      defaultHero.socialProof.students,
    ),
    instructors: pickText(
      sanityHero?.socialProof?.instructors,
      defaultHero.socialProof.instructors,
    ),
    locations: pickText(
      sanityHero?.socialProof?.locations,
      defaultHero.socialProof.locations,
    ),
  },
};

const teachItems = [
  {
    title: "Piano",
    body: "More than just learning dots on the sheet, you will learn what it means to play the song you chose. What key is it? Is it a happy or sad song? What point is the composer trying to make?",
    image: "/piano.webp",
    alt: "Person playing piano with colorful stage lighting",
  },
  {
    title: "Guitar",
    body: "It doesn't have to be hard. Good teachers have a way to fit your fingers on guitar by showing the way that your uncle never thought of.",
    image: "/guitar.jpg",
    alt: "Hands playing an acoustic guitar during a lesson",
  },
  {
    title: "Ukulele",
    body: "Don't let the four strings of a ukulele fool you—you can play almost any song and make it sound great! For faster and complex strumming, ukulele is the choice!",
    image: "/ukulele.jpg",
    alt: "Students learning ukulele",
  },
  {
    title: "Music theory",
    body: "Learn it once and use it on every song. There is a clear pattern and the good teacher will show you the theory behind only the music you are working on.",
    image: "/music%20theory.jpg",
    alt: "Music theory lesson with instruments and sheet music",
  },
] as const;

const pricingPlans = [
  {
    name: "Junior Player",
    price: "$185 FOR 4 LESSONS",
    duration: "30 min",
    recommendations: [
      "Kids Under 10",
      "Adult who want to learn a song or more",
    ],
    image: "/Junior%20Player.webp",
    alt: "Junior Player lesson bundle",
    bookUrl: "https://buy.stripe.com/3cIeVf1uE7iuf35cZib7y00",
  },
  {
    name: "Casual Strummer",
    price: "$255 FOR 4 LESSONS",
    duration: "45 min",
    recommendations: ["Kids over 10 year old", "Casual Learner"],
    image: "/casual%20strummer.jpg",
    alt: "Hands playing piano during a casual music lesson",
    bookUrl: "https://buy.stripe.com/3cIeVf3CM5amcUX0cwb7y01",
  },
  {
    name: "Accelerated Jammer",
    price: "$280 FOR 4 LESSONS",
    duration: "60 min",
    recommendations: [
      "Adults who want to learn fast",
      "Teenagers",
    ],
    image: "/Accelerated%20Jammer.webp",
    alt: "Accelerated Jammer lesson bundle",
    bookUrl: "https://buy.stripe.com/28EcN7flu46icUX6AUb7y04",
  },
  {
    sectionLabel: "Groups",
    sectionAccent: "text-primary",
    name: "Group of Three",
    price: "$28 per student per lesson",
    duration: "1 Hour",
    recommendations: [
      "Family & Friends Lessons",
      "Low pressure and budget",
    ],
    image: "/group.jpg",
    alt: "Group guitar lesson with children outdoors",
  },
  {
    sectionLabel: "À la carte",
    sectionAccent: "text-secondary",
    name: "One Lesson",
    price: "$50",
    duration: "30 min",
    recommendations: [
      "Trial lesson",
      "Irregular Schedule",
      "Project based",
    ],
    image: "/guitar.jpg",
    alt: "One-on-one guitar lesson",
  },
] as const;

const googleReviewsUrl = "https://www.google.com/maps/place/Evergrow+Music+School+-+Piano,+Ukulele,+and+Guitar+Lessons/@34.0666767,-118.356219,13.19z/data=!4m8!3m7!1s0x80c2b98aaaef8665:0x49b7564ba229cf61!8m2!3d34.020479!4d-118.4117326!9m1!1b1!16s%2Fg%2F11h1sq1j1j?entry=ttu&g_ep=EgoyMDI2MDcxOS4wIKXMDSoASAFQAw%3D%3D";

const testimonials = [
  {
    quote:
      "We couldn’t be happier with Johan as our son’s music teacher! He is wonderful, patient, and truly understanding — always making sure lessons are tailored to what works best for my son. What really sets Johan apart is how flexible he is, and how much effort he puts into keeping things fresh and exciting. He’s constantly looking to improve and brings new ideas into every lesson, which keeps my son genuinely engaged and looking forward to each class. The fun atmosphere he creates makes all the difference. Highly recommend Johan to any parent looking for a dedicated and passionate music teacher!",
    name: "Stephania Gambaroff",
    avatar: "/avatar-stephania-gambaroff.png",
    sourceLabel: "Read on Google",
    sourceUrl: "https://maps.app.goo.gl/jB8j5wY6WaL2ufw67",
  },
  {
    quote: `We absolutely love Johan! He is great with my 4th grader and they were making music by the end of their first lesson! He listens to the types of songs he wants to play then incorporates musical chords and scales in his teaching, leading to them playing the song together. It's wonderful to listen to him sing and play at home when he's practicing. Johan also introduces him to different types of instruments, expanding his world of music and musical instruments. We're super thankful to have him as his piano teacher!`,
    name: "Anna Choi",
    avatar: "/avatar-anna-choi.png",
    sourceLabel: "Read on Google",
    sourceUrl: "https://maps.app.goo.gl/ZsFQMV4jLfgt21SG9",
  },
] as const;
---

<Layout>
  <link
    slot="head"
    rel="preload"
    href="/logo-evergrow.webp"
    as="image"
    type="image/webp"
  />
  <link
    slot="head"
    rel="preload"
    href="/studio-room.webp"
    as="image"
    type="image/webp"
    fetchpriority="high"
  />
  <main class="relative bg-slate-950">
    <!-- Hero region: video + gradient only as tall as nav + hero content -->
    <div class="relative isolate">
      <div class="absolute inset-0 z-0 overflow-hidden [container-type:size]">
        <iframe
          class="hero-video"
          src={`https://www.youtube.com/embed/${hero.youtubeVideoId}?autoplay=1&mute=1&loop=1&playlist=${hero.youtubeVideoId}&controls=0&modestbranding=1&playsinline=1&rel=0`}
          title="Hero background video"
          allow="autoplay; encrypted-media; picture-in-picture"
          referrerpolicy="strict-origin-when-cross-origin"></iframe>
      </div>
      <div
        class="pointer-events-none absolute inset-0 z-10 bg-[linear-gradient(110deg,rgba(2,6,23,0.66)_18%,rgba(2,6,23,0.42)_58%,rgba(2,6,23,0.62)_100%)]"
      >
      </div>

      <div class="relative z-20 flex flex-col">
        <header class="relative z-50 shrink-0">
          <nav
            class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-4 text-white md:px-10"
          >
            <a href="/" class="flex shrink-0 items-center gap-3">
              <span
                class="logo-primary block h-10 aspect-[5/2] md:h-22"
                role="img"
                aria-label="evergrow music school"
              ></span>
            </a>
            <div class="hidden items-center gap-8 text-sm md:flex">
              <a href="#" class="transition hover:text-primary">Home</a>
              <a href="#about" class="transition hover:text-primary">About</a>
              <a href="#what-we-teach" class="transition hover:text-primary"
                >Instruments</a
              >
              <a href="#pricing" class="transition hover:text-primary">Pricing</a>
              <a href="#testimonials" class="transition hover:text-primary"
                >Testimonials</a
              >
              <a href="#contact" class="transition hover:text-primary">Contact</a>
            </div>
            <button
              type="button"
              id="student-login-btn"
              aria-haspopup="dialog"
              aria-controls="student-login-modal"
              class="rounded-full bg-primary px-5 py-2 text-xs font-semibold uppercase tracking-wider text-slate-900 shadow-lg shadow-primary-shadow/35 transition hover:bg-primary-hover"
            >
              Student Login
            </button>
          </nav>
        </header>

        <div
          id="student-login-modal"
          class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-950/70 p-4 backdrop-blur-sm"
          role="dialog"
          aria-modal="true"
          aria-labelledby="student-login-title"
        >
          <div
            class="relative w-full max-w-md rounded-3xl bg-white p-6 text-slate-900 shadow-2xl shadow-black/40 md:p-8"
          >
            <div class="mb-4 flex items-center justify-between gap-4">
              <h2
                id="student-login-title"
                class="text-lg font-bold tracking-tight"
              >
                Student Login
              </h2>
              <button
                type="button"
                id="student-login-close"
                class="rounded-full px-3 py-1 text-sm font-semibold text-slate-500 transition hover:bg-slate-100 hover:text-slate-900"
                aria-label="Close student login"
              >
                Close
              </button>
            </div>
            <div
              id="student-login-widget"
              class="min-h-[200px] rounded-xl border border-slate-200 bg-slate-50/70 p-3"
            >
              <script
                is:inline
                src="https://app.mymusicstaff.com/Widget/v4/Widget.ashx?settings=eyJTY2hvb2xJRCI6InNjaF9yVjFKQyIsIldlYnNpdGVJRCI6Indic19kMW5KViIsIldlYnNpdGVCbG9ja0lEIjoid2JiX3pGUjVZSk0ifQ=="
              ></script>
            </div>
          </div>
        </div>

        <section
          class="mx-auto flex w-full max-w-7xl flex-col px-6 pb-12 pt-6 md:px-10 lg:pb-20 lg:pt-10"
        >
          <div
            class="flex w-full flex-col items-stretch gap-8 lg:flex-row lg:items-end lg:justify-between lg:gap-20"
          >
            <div class="w-full lg:mb-80 shrink-0 lg:flex-1">
              <p
                class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-primary"
              >
                {hero.badge}
              </p>
              <h1
                class="max-w-xl text-4xl font-extrabold leading-none sm:text-5xl md:text-6xl lg:text-6xl"
              >
                <span class="text-white">Music Lessons</span>{" "}
               <br/> <span class="text-white">in Los Angeles</span>
              </h1>
              <p
                class="mt-6 max-w-xl text-xl leading-tight text-slate-200 md:text-3xl"
              >
                {hero.description}
              </p>
              <div class="mt-8 flex flex-wrap gap-3 text-sm text-slate-200">
                {
                  hero.featureChips.map((chip) => (
                    <span class="rounded-full border border-white/30 bg-white/10 px-4 py-2">
                      {chip}
                    </span>
                  ))
                }
              </div>
            </div>
            <!-- lead form -->
            <div
              class="relative mx-auto w-full max-w-[480px] shrink-0 rounded-3xl border border-slate-200/10 bg-white p-8 text-slate-900 shadow-2xl shadow-black/40 md:p-10 lg:mx-0"
            >
              <div id="lead-form"></div>
              <p
                class="text-center text-sm font-semibold uppercase tracking-[0.15em] text-primary"
              >
                {hero.offerLabel}
              </p>
              <h2 class="mt-2 text-center text-3xl font-bold leading-tight">
             
              </h2>
              <p class="mt-2 text-center text-sm text-slate-500">
                {hero.offerDescription}
              </p>

              <div
                class="rounded-xl border border-slate-200 bg-slate-50/70 p-3"
              >
                <!-- <script
							is:inline
							src="https://app.mymusicstaff.com/Widget/v4/Widget.ashx?settings=eyJTY2hvb2xJRCI6InNjaF9yVjFKQyIsIldlYnNpdGVJRCI6Indic19kMW5KViIsIldlYnNpdGVCbG9ja0lEIjoid2JiX3pGUjVwSlEifQ=="
						></script> -->
                <script
                  is:inline
                  src="https://app.mymusicstaff.com/Widget/v4/Widget.ashx?settings=eyJTY2hvb2xJRCI6InNjaF9yVjFKQyIsIldlYnNpdGVJRCI6Indic19kMW5KViIsIldlYnNpdGVCbG9ja0lEIjoid2JiX3p3SHo5SlYifQ=="
                ></script>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>

    <!-- About / lessons overview -->
    <section
      id="about"
      class="relative z-30 bg-white pb-30 rounded-t-[60px] -mt-[60px] text-slate-900 scroll-mt-6"
      aria-labelledby="about-lessons-heading"
    >
      <div
        class="mx-auto grid max-w-7xl gap-12 px-6 py-16 md:px-10 md:py-24 lg:grid-cols-2 lg:items-center lg:gap-16"
      >
        <div class="order-2 flex flex-col justify-center lg:order-1">
          <h2
            id="about-lessons-heading"
            class="text-4xl font-bold tracking-tight md:text-5xl"
          >
            Music Lessons In LA
          </h2>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-700">
            Sharing music since 2014. LA 90004 and surrounding areas. Lessons
            are available at the student's home, the teacher's studio, or
            online.
          </p>
          <h3 class="mt-10 text-2xl font-bold tracking-tight md:text-3xl">
            Why choose Evergrow?
          </h3>
          <p class="mt-4 max-w-xl text-lg leading-relaxed text-slate-700">
            Music grows and changes over time—and teaching music should too. The
            old tradition of only playing what's on paper doesn't help you
            enough to really feel the music. Let learning music become a
            lifetime journey, not a painful memory.
          </p>
          <a
            href="#lead-form"
            class="mt-10 inline-flex w-fit items-center justify-center rounded-full bg-primary px-8 py-3 text-sm font-semibold uppercase tracking-wider text-slate-900 underline decoration-2 underline-offset-4 shadow-md shadow-primary-shadow/25 transition hover:bg-primary-hover"
          >
            Lesson inquiry
          </a>
        </div>
        <div class="order-1 lg:order-2">
          <figure class="overflow-hidden rounded-3xl shadow-xl shadow-black/10">
            <picture>
              <source srcset="/studio-room.webp" type="image/webp" />
              <img
                src="/studio-room-1280.jpeg"
                alt="Evergrow Music School teaching studio with piano and guitars"
                class="aspect-4/3 h-auto w-full object-cover"
                width="1280"
                height="960"
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
            </picture>
          </figure>
        </div>
      </div>
    </section>

    <section
      id="what-we-teach"
      class="scroll-mt-6 bg-white"
      aria-labelledby="what-we-teach-heading"
    >        <h2
          id="what-we-teach-heading"
          class="text-center text-4xl font-bold uppercase tracking-tight text-secondary sm:text-5xl md:text-6xl lg:text-7xl mb-10"
        >
          What we teach !
        </h2>
      <div class="mx-auto max-w-7xl what-we-teach-section  rounded-[50px] text-white px-[60px] py-6 ">


        <div
          class="mt-14 grid gap-14 px-6  md:mt-20 md:gap-16 lg:grid-cols-2 lg:gap-x-16 lg:gap-y-20"
        >
          {
            teachItems.map((item) => (
              <article class="flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-8 lg:gap-10">
                <div class="mx-auto w-full shrink-0 overflow-hidden rounded-2xl shadow-md shadow-black/10 sm:mx-0 sm:w-44 md:w-52 lg:w-56">
                  <div class="relative aspect-square">
                    <img
                      src={item.image}
                      alt={item.alt}
                      width={400}
                      height={400}
                      loading="lazy"
                      decoding="async"
                      class="absolute inset-0 h-full w-full object-cover object-center"
                    />
                  </div>
                </div>
                <div class="min-w-0 flex-1 text-center sm:text-left">
                  <h3 class="text-xl font-bold uppercase tracking-wide text-white md:text-2xl">
                    {item.title}
                  </h3>
                  <p class="mt-3 text-base leading-relaxed text-white md:text-lg">
                    {item.body}
                  </p>
                </div>
              </article>
            ))
          }
        </div>

        <div class="mt-16 flex justify-center mb-10 md:mt-20">
          <a
            href="#lead-form"
            class="inline-flex min-w-56 items-center justify-center rounded-full border-2 border-white bg-transparent px-12 py-4 text-sm font-bold uppercase tracking-wider text-white underline decoration-2 underline-offset-[0.2em] transition hover:bg-white/15 md:text-base"
          >
            Book a lesson
          </a>
        </div>
      </div>
    </section>

    <section
      id="pricing"
      class="relative z-30 scroll-mt-6 bg-white text-slate-900"
      aria-labelledby="lesson-deals-heading"
    >
      <div class="mx-auto max-w-7xl px-6 py-16 md:px-10 md:py-24 lg:py-28">
        <h2
          id="lesson-deals-heading"
          class="text-center text-4xl font-bold uppercase tracking-tight sm:text-5xl md:text-6xl"
        >
          <span class="text-primary">Lesson</span>{" "}
          <span class="text-secondary">Deals</span>{" "}
          <span class="text-slate-900">Bundle</span>
        </h2>

        <div
          class="mt-12 grid gap-8 md:mt-16 md:grid-cols-2 md:gap-10 lg:grid-cols-3"
        >
          {
            pricingPlans.map((plan) => (
              <div class="flex flex-col">
                {"sectionLabel" in plan && (
                  <h3
                    class:list={[
                      "mb-6 text-center text-3xl font-bold uppercase tracking-tight md:text-4xl",
                      plan.sectionAccent,
                    ]}
                  >
                    {plan.sectionLabel}
                  </h3>
                )}
                <article class="flex flex-1 flex-col overflow-hidden rounded-2xl shadow-lg shadow-black/10 ring-1 ring-slate-200/80">
                  <div class="relative aspect-4/3 overflow-hidden">
                    <img
                      src={plan.image}
                      alt={plan.alt}
                      width={600}
                      height={450}
                      loading="lazy"
                      decoding="async"
                      class="absolute inset-0 h-full w-full object-cover object-center"
                    />
                    <div
                      class="absolute inset-0 bg-linear-to-t from-slate-950/80 via-slate-950/25 to-transparent"
                      aria-hidden="true"
                    />
                    <div class="absolute bottom-0 left-0 p-5">
                      <h4 class="text-lg font-bold uppercase leading-tight tracking-wide text-white md:text-xl">
                        {plan.name}
                      </h4>
                      <p class="mt-1 text-sm font-semibold uppercase tracking-wide text-white/95">
                        {plan.price}
                      </p>
                    </div>
                  </div>

                  <div class="flex flex-1 flex-col bg-white px-5 py-6 md:px-6 md:py-7">
                    <ul class="list-disc space-y-3 pl-5 text-sm text-slate-800 md:text-base">
                      <li>{plan.duration}</li>
                      <li>
                        Recommend for
                        <ul class="mt-2 list-disc space-y-1 pl-5">
                          {plan.recommendations.map((item) => (
                            <li>{item}</li>
                          ))}
                        </ul>
                      </li>
                    </ul>
                    <a
                      href={"bookUrl" in plan ? plan.bookUrl : "#lead-form"}
                      target={"bookUrl" in plan ? "_blank" : undefined}
                      rel={"bookUrl" in plan ? "noopener noreferrer" : undefined}
                      class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-bold uppercase tracking-wider text-slate-900 shadow-md shadow-primary-shadow/25 transition hover:bg-primary-hover"
                    >
                      Book now
                    </a>
                  </div>
                </article>
              </div>
            ))
          }
        </div>

        <p class="mt-10 text-center text-sm text-slate-600 md:mt-12">
          *** Add Home visit for $25 per lesson · Groups home visit $20 fee
        </p>
      </div>
    </section>

    <section
      id="testimonials"
      class="relative z-30 scroll-mt-6 overflow-hidden bg-white text-slate-900"
      aria-labelledby="testimonials-heading"
    >
      <div class="mx-auto max-w-7xl px-6 py-16 md:px-10 md:py-24 lg:py-28">
        <div
          class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between lg:gap-16"
        >
          <div class="max-w-3xl">
            <h2
              id="testimonials-heading"
              class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl md:text-6xl"
            >
              What Are They Saying
            </h2>
            <p class="mt-6 text-base leading-relaxed text-slate-600 md:text-lg">
              Evergrow Music School has built a strong reputation for excellence
              since our founding in 2014. Families consistently share their
              experiences across platforms such as Google, Yelp, and Facebook.
              Below are just a few testimonials from students and families who
              have enjoyed their experience with our school.
            </p>
          </div>
          <a
            href={googleReviewsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex shrink-0 items-center gap-2 self-start rounded-full bg-primary px-6 py-3 text-sm font-bold text-slate-900 shadow-md shadow-primary-shadow/25 transition hover:bg-primary-hover lg:self-auto"
          >
            View all
            <span aria-hidden="true">↗</span>
          </a>
        </div>

        <div
          class="mt-12 grid gap-6 md:mt-16 md:grid-cols-2 md:gap-8 lg:grid-cols-3"
        >
          {
            testimonials.map((review) => (
              <article class="flex flex-col rounded-2xl bg-slate-50 p-6 ring-1 ring-slate-200/80 md:p-8">
                <div
